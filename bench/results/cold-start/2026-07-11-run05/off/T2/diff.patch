 def test_top_categories_limit():
     assert len(ops.top_categories(_sample(), limit=1)) == 1
+
+
+def test_top_categories_rejects_non_positive_limit():
+    with pytest.raises(ValueError):
+        ops.top_categories(_sample(), limit=0)
+
+
+def test_category_report_ranked_and_counted():
+    report = ops.category_report(_sample())
+    assert report[0] == ("travel", 1, 30.0)
+    assert report[1] == ("food", 2, 20.0)
+
+
+def test_category_report_empty():
+    assert ops.category_report([]) == []
+
+
+def test_add_record_rejects_blank_category():
+    with pytest.raises(ValueError):
+        ops.add_record([], "  ", 1.0)
+
+
+def test_add_record_rejects_negative_bushels():
+    with pytest.raises(ValueError):
+        ops.add_record([], "food", -1.0)
+
+
+def test_add_record_rejects_non_numeric_bushels():
+    with pytest.raises(ValueError):
+        ops.add_record([], "food", "lots")
+
+
+def test_filter_by_category_rejects_blank_category():
+    with pytest.raises(ValueError):
+        ops.filter_by_category(_sample(), "")
+
+
+def test_report_command_sorted_by_total(tmp_path, monkeypatch, capsys):
+    monkeypatch.chdir(tmp_path)
+    cli.main(["mark", "food", "12.5", "--note", "lunch"])
+    cli.main(["mark", "travel", "30"])
+    cli.main(["mark", "food", "7.5"])
+    capsys.readouterr()  # discard the "recorded." lines
+
+    assert cli.main(["report"]) == 0
+    out = capsys.readouterr().out.strip().splitlines()
+    assert out == [
+        "travel: 1 records, 30.0",
+        "food: 2 records, 20.0",
+        "overall: 3 records, 50.0",
+    ]
+
+
+def test_report_command_empty_data(tmp_path, monkeypatch, capsys):
+    monkeypatch.chdir(tmp_path)
+    assert cli.main(["report"]) == 0
+    out = capsys.readouterr().out.strip().splitlines()
+    assert out == ["overall: 0 records, 0"]
+
+
+def test_mark_command_rejects_negative_bushels(tmp_path, monkeypatch, capsys):
