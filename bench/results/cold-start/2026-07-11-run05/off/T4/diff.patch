diff --git a/juniperharvest/ops.py b/juniperharvest/ops.py
index e07e3f7..386ffe9 100644
--- a/juniperharvest/ops.py
+++ b/juniperharvest/ops.py
@@ -59,3 +59,26 @@ def category_report(records):
         stats[r["category"]] = (count + 1, total + r["bushels"])
     ranked = sorted(stats.items(), key=lambda kv: (-kv[1][1], kv[0]))
     return [(category, count, total) for category, (count, total) in ranked]
+
+
+def _validate_budget(amount):
+    try:
+        amount = float(amount)
+    except (TypeError, ValueError):
+        raise ValueError("budget must be a number") from None
+    if amount < 0:
+        raise ValueError("budget must not be negative")
+    return amount
+
+
+def set_budget(budgets, category, amount):
+    """Set (or replace) the budget for a category and return the stored amount."""
+    _validate_category(category)
+    amount = _validate_budget(amount)
+    budgets[category] = amount
+    return amount
+
+
+def is_over_budget(total, budget):
+    """Return whether ``total`` exceeds ``budget`` (``budget`` may be ``None``)."""
+    return budget is not None and total > budget
