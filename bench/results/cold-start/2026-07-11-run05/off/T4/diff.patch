-"""JSON-file persistence for juniperharvest — one list of harvest records."""
+"""JSON-file persistence for juniperharvest — records and category budgets."""
 
 import json
 from pathlib import Path
 
 DEFAULT_PATH = Path("harvests.json")
+DEFAULT_BUDGETS_PATH = Path("budgets.json")
 
 
 def load_records(path=DEFAULT_PATH):
@@ -17,3 +18,16 @@ def load_records(path=DEFAULT_PATH):
 def save_records(records, path=DEFAULT_PATH):
     """Write the harvest records back to disk."""
     Path(path).write_text(json.dumps(records, indent=2), encoding="utf-8")
+
+
+def load_budgets(path=DEFAULT_BUDGETS_PATH):
+    """Return the stored category budgets (empty dict when no file)."""
+    path = Path(path)
+    if not path.exists():
+        return {}
+    return json.loads(path.read_text(encoding="utf-8"))
+
+
+def save_budgets(budgets, path=DEFAULT_BUDGETS_PATH):
+    """Write the category budgets back to disk."""
+    Path(path).write_text(json.dumps(budgets, indent=2), encoding="utf-8")
diff --git a/tests/test_juniperharvest.py b/tests/test_juniperharvest.py
index caa86f4..cd92fce 100644
--- a/tests/test_juniperharvest.py
+++ b/tests/test_juniperharvest.py
@@ -103,3 +103,80 @@ def test_mark_command_rejects_negative_bushels(tmp_path, monkeypatch, capsys):
     monkeypatch.chdir(tmp_path)
     assert cli.main(["mark", "food", "-1"]) == 1
     assert "error" in capsys.readouterr().err
+
+
+def test_set_budget_stores_amount():
+    budgets = {}
+    assert ops.set_budget(budgets, "food", 25.0) == 25.0
+    assert budgets == {"food": 25.0}
+
+
+def test_set_budget_replaces_existing():
+    budgets = {"food": 10.0}
+    ops.set_budget(budgets, "food", 5.0)
+    assert budgets == {"food": 5.0}
+
+
+def test_set_budget_rejects_blank_category():
+    with pytest.raises(ValueError):
+        ops.set_budget({}, "  ", 10.0)
+
+
+def test_set_budget_rejects_negative_amount():
+    with pytest.raises(ValueError):
+        ops.set_budget({}, "food", -5.0)
+
+
+def test_is_over_budget_true_when_total_exceeds():
+    assert ops.is_over_budget(30.0, 20.0) is True
+
+
+def test_is_over_budget_false_when_within():
+    assert ops.is_over_budget(20.0, 20.0) is False
+
+
+def test_is_over_budget_false_when_no_budget_set():
+    assert ops.is_over_budget(30.0, None) is False
+
+
+def test_budget_command_sets_budget(tmp_path, monkeypatch, capsys):
+    monkeypatch.chdir(tmp_path)
+    assert cli.main(["budget", "food", "20"]) == 0
+    assert "budget set." in capsys.readouterr().out
+
+
+def test_budget_command_rejects_negative_amount(tmp_path, monkeypatch, capsys):
+    monkeypatch.chdir(tmp_path)
+    assert cli.main(["budget", "food", "-5"]) == 1
+    assert "error" in capsys.readouterr().err
+
+
+def test_report_flags_category_over_budget(tmp_path, monkeypatch, capsys):
+    monkeypatch.chdir(tmp_path)
+    cli.main(["mark", "food", "12.5", "--note", "lunch"])
+    cli.main(["mark", "travel", "30"])
+    cli.main(["mark", "food", "7.5"])
+    cli.main(["budget", "food", "15"])
+    capsys.readouterr()  # discard the "recorded."/"budget set." lines
+
+    assert cli.main(["report"]) == 0
+    out = capsys.readouterr().out.strip().splitlines()
+    assert out == [
+        "travel: 1 records, 30.0",
+        "food: 2 records, 20.0 -- OVER BUDGET (budget: 15.0)",
+        "overall: 3 records, 50.0",
+    ]
+
+
+def test_report_does_not_flag_category_within_budget(tmp_path, monkeypatch, capsys):
+    monkeypatch.chdir(tmp_path)
+    cli.main(["mark", "food", "12.5"])
+    cli.main(["budget", "food", "20"])
+    capsys.readouterr()
+
+    assert cli.main(["report"]) == 0
+    out = capsys.readouterr().out.strip().splitlines()
+    assert out == [
+        "food: 1 records, 12.5",
+        "overall: 1 records, 12.5",
+    ]
