--- a/galereading/ops.py
+++ b/galereading/ops.py
@@ -37,6 +37,26 @@ def category_report(records):
     )
 
 
+def set_budget(budgets, category, amount):
+    """Set the budget for a category (overwriting any prior one) and return it."""
+    budgets[category] = float(amount)
+    return budgets[category]
+
+
+def over_budget_categories(records, budgets):
+    """Return ``{category: (total, budget)}`` for categories over their budget.
+
+    A category is over budget when its summed value strictly exceeds its
+    budget; categories without a budget are never flagged. Category names
+    match exactly, the same grouping ``category_report`` uses.
+    """
+    return {
+        category: (total, budgets[category])
+        for category, _count, total in category_report(records)
+        if category in budgets and total > budgets[category]
+    }
+
+
