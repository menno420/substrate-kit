--- a/galereading/store.py
+++ b/galereading/store.py
@@ -1,9 +1,10 @@
-"""JSON-file persistence for galereading — one list of reading records."""
+"""JSON-file persistence for galereading — reading records plus budgets."""
 
 import json
 from pathlib import Path
 
 DEFAULT_PATH = Path("readings.json")
+DEFAULT_BUDGETS_PATH = Path("budgets.json")
 
 
 def load_records(path=DEFAULT_PATH):
@@ -17,3 +18,16 @@ def load_records(path=DEFAULT_PATH):
 def save_records(records, path=DEFAULT_PATH):
     """Write the reading records back to disk."""
     Path(path).write_text(json.dumps(records, indent=2), encoding="utf-8")
+
+
+def load_budgets(path=DEFAULT_BUDGETS_PATH):
+    """Return the stored per-category budgets (empty dict when no file)."""
+    path = Path(path)
+    if not path.exists():
+        return {}
+    return json.loads(path.read_text(encoding="utf-8"))
+
+
+def save_budgets(budgets, path=DEFAULT_BUDGETS_PATH):
+    """Write the per-category budgets back to disk."""
+    Path(path).write_text(json.dumps(budgets, indent=2), encoding="utf-8")
