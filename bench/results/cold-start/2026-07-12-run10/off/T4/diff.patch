 """Tests for irisdonation core operations."""
 
+import pytest
+
 from irisdonation import ops
 
 
@@ -37,3 +39,76 @@ def test_top_categories_ranked():
 
 def test_top_categories_limit():
     assert len(ops.top_categories(_sample(), limit=1)) == 1
+
+
+def test_top_categories_rejects_non_positive_limit():
+    with pytest.raises(ValueError):
+        ops.top_categories(_sample(), limit=0)
+
+
+def test_report_ranked_by_total_desc():
+    assert ops.report(_sample()) == [
+        ("travel", 1, 30.0, None),
+        ("food", 2, 20.0, None),
+    ]
+
+
+def test_report_empty_records():
+    assert ops.report([]) == []
+
+
+def test_add_record_rejects_blank_category():
+    with pytest.raises(ValueError):
+        ops.add_record([], "  ", 1.0)
+
+
+def test_add_record_rejects_non_positive_amount():
+    with pytest.raises(ValueError):
+        ops.add_record([], "food", 0)
+
+
+def test_add_record_rejects_non_finite_amount():
+    with pytest.raises(ValueError):
+        ops.add_record([], "food", float("inf"))
+
+
+def test_add_record_strips_category_whitespace():
+    record = ops.add_record([], "  food  ", 1.0)
+    assert record["category"] == "food"
+
+
+def test_filter_by_category_rejects_blank_category():
+    with pytest.raises(ValueError):
+        ops.filter_by_category(_sample(), "  ")
+
+
+def test_set_budget_stores_amount():
+    budgets = {}
+    assert ops.set_budget(budgets, "food", 25.0) == 25.0
+    assert budgets == {"food": 25.0}
+
+
+def test_set_budget_rejects_blank_category():
+    with pytest.raises(ValueError):
+        ops.set_budget({}, "  ", 25.0)
+
+
+def test_set_budget_rejects_non_positive_amount():
+    with pytest.raises(ValueError):
+        ops.set_budget({}, "food", 0)
+
+
+def test_report_includes_budget_for_category():
+    budgets = {"food": 25.0}
+    assert ops.report(_sample(), budgets) == [
+        ("travel", 1, 30.0, None),
+        ("food", 2, 20.0, 25.0),
+    ]
+
+
+def test_report_over_budget_category_is_identifiable():
+    budgets = {"travel": 25.0}
+    ranked = ops.report(_sample(), budgets)
+    category, count, total, budget = ranked[0]
+    assert category == "travel"
+    assert budget is not None and total > budget
