diff --git a/harborride/ops.py b/harborride/ops.py
index 6e7c2ad..11f88ff 100644
--- a/harborride/ops.py
+++ b/harborride/ops.py
@@ -43,3 +43,18 @@ def category_report(records):
         stats[r["category"]] = (count + 1, total + r["distance"])
     ranked = sorted(stats.items(), key=lambda kv: (-kv[1][1], kv[0]))
     return [(category, count, total) for category, (count, total) in ranked]
+
+
+def set_budget(budgets, category, amount):
+    """Set the spending budget for a category and return the amount."""
+    budgets[category] = float(amount)
+    return budgets[category]
+
+
+def is_over_budget(total, budget):
+    """Return True when a category's total exceeds its budget.
+
+    A ``budget`` of ``None`` (no budget set for the category) is never
+    considered over budget.
+    """
+    return budget is not None and total > budget
diff --git a/harborride/store.py b/harborride/store.py
index 284639d..8ad5364 100644
--- a/harborride/store.py
+++ b/harborride/store.py
@@ -4,6 +4,7 @@ import json
 from pathlib import Path
 
 DEFAULT_PATH = Path("rides.json")
+DEFAULT_BUDGETS_PATH = Path("budgets.json")
 
 
 def load_records(path=DEFAULT_PATH):
@@ -17,3 +18,16 @@ def load_records(path=DEFAULT_PATH):
 def save_records(records, path=DEFAULT_PATH):
     """Write the ride records back to disk."""
     Path(path).write_text(json.dumps(records, indent=2), encoding="utf-8")
+
+
+def load_budgets(path=DEFAULT_BUDGETS_PATH):
+    """Return the stored category budgets (empty dict when no file)."""
+    path = Path(path)
+    if not path.exists():
+        return {}
+    return json.loads(path.read_text(encoding="utf-8"))
+
+
+def save_budgets(budgets, path=DEFAULT_BUDGETS_PATH):
+    """Write the category budgets back to disk."""
+    Path(path).write_text(json.dumps(budgets, indent=2), encoding="utf-8")
diff --git a/tests/test_harborride.py b/tests/test_harborride.py
index 4d07ef7..5195dde 100644
--- a/tests/test_harborride.py
+++ b/tests/test_harborride.py
@@ -4,7 +4,7 @@ import argparse
 
 import pytest
 
-from harborride import cli, ops
+from harborride import cli, ops, store
 
 
 def _sample():
@@ -94,3 +94,61 @@ def test_limit_arg_rejects_zero():
 
 def test_limit_arg_accepts_positive_value():
     assert cli._limit_arg("2") == 2
+
+
+def test_budget_arg_rejects_negative():
+    with pytest.raises(argparse.ArgumentTypeError):
+        cli._budget_arg("-1")
+
+
+def test_budget_arg_rejects_non_finite():
+    with pytest.raises(argparse.ArgumentTypeError):
+        cli._budget_arg("nan")
+
+
+def test_budget_arg_rejects_non_numeric():
+    with pytest.raises(argparse.ArgumentTypeError):
+        cli._budget_arg("abc")
+
+
+def test_budget_arg_accepts_valid_value():
+    assert cli._budget_arg("15") == 15.0
+
+
+def test_set_budget_stores_and_returns_amount():
+    budgets = {}
+    assert ops.set_budget(budgets, "food", 15) == 15.0
+    assert budgets["food"] == 15.0
+
+
+def test_set_budget_overwrites_existing():
+    budgets = {"food": 10.0}
+    ops.set_budget(budgets, "food", 25)
+    assert budgets["food"] == 25.0
+
+
+def test_is_over_budget_true_when_total_exceeds():
+    assert ops.is_over_budget(20.0, 15.0) is True
+
+
+def test_is_over_budget_false_when_within():
+    assert ops.is_over_budget(10.0, 15.0) is False
+
+
+def test_is_over_budget_false_when_equal():
+    assert ops.is_over_budget(15.0, 15.0) is False
+
+
+def test_is_over_budget_false_when_no_budget_set():
+    assert ops.is_over_budget(1000.0, None) is False
+
+
+def test_budgets_round_trip(tmp_path):
+    path = tmp_path / "budgets.json"
+    store.save_budgets({"food": 15.0}, path=path)
+    assert store.load_budgets(path=path) == {"food": 15.0}
+
+
+def test_load_budgets_missing_file_returns_empty_dict(tmp_path):
+    path = tmp_path / "missing-budgets.json"
+    assert store.load_budgets(path=path) == {}
